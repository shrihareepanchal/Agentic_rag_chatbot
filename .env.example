# ── LLM Configuration ──────────────────────────────────────────────────────
OPENAI_API_KEY=                                # Leave blank to use MOCK_MODE
OPENAI_BASE_URL=https://api.openai.com/v1  # Override for Ollama / LM Studio
LLM_MODEL=gpt-4o-mini                      # or llama3, mistral, etc.
EMBEDDING_MODEL=text-embedding-3-small     # or nomic-embed-text for Ollama

# ── Mock / Dev Mode ────────────────────────────────────────────────────────
MOCK_MODE=false          # Set true to skip all LLM calls (deterministic responses)

# ── Vector Store (ChromaDB) ────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ── Structured Store (SQLite) ──────────────────────────────────────────────
SQLITE_DB_PATH=./data/structured.db

# ── Ingestion ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_FILE_SIZE_MB=50

# ── Agent ─────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.25  # Below this → "I don't know" response

# ── Guardrails ─────────────────────────────────────────────────────────────
ENABLE_PII_REDACTION=false  # Set true to redact PII from user queries
ENABLE_INJECTION_GUARD=true

# ── API Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
```

